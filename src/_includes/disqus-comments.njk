{% if comments != false and isProduction %}

  <div id="disqus_thread"></div>
  <script>
    var disqus_config = function () {
      this.page.url = '{{ page.url | absoluteUrl }}';
      this.page.identifier = '{{ page.url | absoluteUrl }}';
    };

    (function() {
      var d = document, s = d.createElement('script');

      s.src = 'https://{{ site.disqus.shortname }}.disqus.com/embed.js';

      s.setAttribute('data-timestamp', +new Date());
      (d.head || d.body).appendChild(s);
    })();
  </script>
  <noscript>Por favor, habilite o JavaScript para ver os <a href="https://disqus.com/?ref_noscript" rel="nofollow">comentários disponibilizados pelo Disqus.</a></noscript>
{% endif %}
